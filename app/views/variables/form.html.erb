<% if user_signed_in? %>
<% if current_user.admin? %>


    <%= form_tag :action =>'form' do %>
    <p>Empresa:
    <%= select_tag "empresa_id", raw("<option value=1 >Industrias</option>" "<option value=2 >Confecciones</option>") %><p/>
      <p>Origen:
      <%= select_tag "origen_de", raw("<option value=1 >compras</option>" "<option value=2 >ventas</option>") %><p/>
          <p>Mes:
      <%= select_date Date.today, :prefix=> :mes_de, discard_day:true %><p/>
    <%= submit_tag 'Registrar' %>


  <% end %>
<% end %>
<% end %>
