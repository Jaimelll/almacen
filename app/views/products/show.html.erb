<p id="notice"><%= notice %></p>
<h2>PRODUCTOS INGRESO DE FORMULA </h2>
<p>
  <strong>Nombre:</strong>
  <%= @product.nombre %>
</p>

<p>
  <strong>Descripcion:</strong>
  <%= @product.descripcion %>
</p>

<p>
  <strong>Precio:</strong>
  <%= @product.precio %>
</p>

<p>
  <strong>Moneda:</strong>
  <%= @product.moneda %>
</p>

<p>
  <strong>Unidad:</strong>
  <%= @product.unidad %>
</p>


<% if @product.client_id!=881 %>
<p>
  <strong>Client:</strong>
  <%= @product.client.razon %>
</p>
<% end %>


<p>
  <strong>Material:</strong>
  <%= @product.material %>
</p>

<p>
  <strong>Lote:</strong>
  <%= @product.lote %>
</p>

<p>
  <strong>Proceso:</strong>
  <%= @product.proceso %>
</p>

<p>
  <strong>Equivalente:</strong>
  <%= Product.find_by_id(@product.equivalente).nombre if @product.equivalente %>
</p>

<p>
  <strong>Conversion:</strong>
  <%= @product.conversion %>
</p>


<h3>FORMULAS</h3>

<table>
  <thead>
    <tr>
      <th  style="width:100px;">Material</th>
      <th  style="width:100px;">Cantidad</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @product.formulas.each do |formula| %>
      <tr>
        <td><%= Product.find_by_id(formula.material).nombre if formula.material %></td>
        <td><%= formula.cantidad %></td>
        <td  style="width:100px;"><%= link_to 'Edit', edit_product_formula_path(@product,formula) %></td>
        <td  style="width:100px;"><%= link_to 'Destroy', product_formula_path(@product,formula), method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<h3><%= link_to 'New Formula', new_product_formula_path(@product) %></h3>
<p></p>

<%= link_to 'Edit', edit_product_path(@product) %> |
<%= link_to 'Back', products_path %>
