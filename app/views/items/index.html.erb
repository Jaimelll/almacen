<p id="notice"><%= notice %></p>

<h1>Partes</h1>


<h2 >PARAMETROS :

  <%if Parameter.find_by_id(1).origen==1 %>
    Compras
   <%end %>
   <%if Parameter.find_by_id(1).origen==2 %>
     Ventas
  <%end %>
  <%if Parameter.find_by_id(1).origen==3 %>
      Pedido
  <%end %>
  <%if Parameter.find_by_id(1).origen==4 %>
       Orden de compra
  <%end %>
  <%if Parameter.find_by_id(1).origen==5 %>
       Produccion
   <%end %>
   <%if Parameter.find_by_id(1).origen==6 %>
      Inventario
    <%end %>


</h2>
     <h3>
       <strong class="para"> EMPRESA =</strong>

        <%if Parameter.find_by_id(1).empresa==1 %>
            Mario
        <%end %>
        <%if Parameter.find_by_id(1).empresa==2 %>
           Confecciones
         <%end %>
         <%if Parameter.find_by_id(1).empresa==3 %>
            Industrias
        <%end %>
      <strong class="para"> PERIODO =</strong>
        <%= Parameter.find_by_id(1).mes.strftime("%b")  %>-<%=Parameter.find_by_id(1).mes.strftime("%Y") %>
      <strong class="para"> REGISTROS =</strong>
          <%=@regis %>
      <% if @acum>0 %>
      <strong class="para"> SUBTOTAL =</strong>
        <%= '%.2f' % (@acum) %>
      <% end %>
                  </h3>
<br/>
<table>
  <thead>
    <tr>
      <th style="width:100px;">Pfecha</th>
    <% if Parameter.find_by_id(1).origen<5 %>
      <th style="width:50px;">Serie</th>
      <th style="width:70px;">Factura</th>
      <th style="width:100px;">Ruc</th>
      <th style="width:350px;">Razon</th>
      <th style="width:100px;">Subtotal</th>
      <th style="width:50px;">Moneda</th>
      <th style="width:50px;">Tc</th>
    <% end %>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @items.each do |item| %>
      <tr>
        <td><%= item.pfecha %></td>
        <% if Parameter.find_by_id(1).origen<5 %>
        <td><%= item.serie %></td>
        <td><%= item.nfactu %></td>
        <td><%= item.client.ruc if item.client %></td>
        <td><%= item.client.razon if item.client %></td>
        <td><%= '%.2f' % (item.subtotal) %></td>
        <td><%= item.moneda %></td>
        <td><%= item.tc %></td>
          <% end %>
        <td  style="width:60px;"><%= link_to 'Mostrar', item %></td>
        <td  style="width:60px;"><%= link_to 'Editar', edit_item_path(item) %></td>
        <td  style="width:60px;"><%= link_to 'Eliminar', item, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>

  </tbody>
</table>
<br/>
  <%= link_to 'Imprimir partes', items_url(format: :pdf)%>

<br/>
<br>


<%= link_to 'Nuevo Parte', new_item_path %>
