<p id="notice"><%= notice %></p>

<h1>Partes</h1>


<h2>PARAMETROS
  <%if Parameter.find_by_id(1).origen==1 %>
    Compras
   <%end %>
   <%if Parameter.find_by_id(1).origen==2 %>
     Ventas
  <%end %>
  <%if Parameter.find_by_id(1).origen==3 %>
      Parte
  <%end %>
  <%if Parameter.find_by_id(1).origen==4 %>
       Inventario
  <%end %>
  <%if Parameter.find_by_id(1).origen==5 %>
       Pedido
   <%end %>

</h2>
     <h3>
       EMPRESA =
       <%if Parameter.find_by_id(1).empresa==1 %>
         Industrias
        <%end %>
        <%if Parameter.find_by_id(1).empresa==2 %>
          Confecciones
         <%end %>

       PERIODO =    <%= Parameter.find_by_id(1).mes.strftime("%b")  %>-<%=Parameter.find_by_id(1).mes.strftime("%Y") %>
       REGISTROS =  <%=@regis %>
      <% if @acum>0 %>
      SUBTOTAL =  <%=@acum %>
      <% end %>
                  </h3>

<table>
  <thead>
    <tr>
      <th>Pfecha</th>
    <% if Parameter.find_by_id(1).origen<3 %>
      <th>Serie</th>
      <th>Factura</th>
      <th>Ruc</th>
      <th>Razon</th>
      <th>Subtotal</th>
      <th>Moneda</th>
      <th>Tc</th>
    <% end %>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @items.each do |item| %>
      <tr>
        <td><%= item.pfecha %></td>
        <% if Parameter.find_by_id(1).origen<3 %>
        <td><%= item.serie %></td>
        <td><%= item.nfactu %></td>
        <td><%= item.client.ruc if item.client %></td>
        <td><%= item.client.razon if item.client %></td>
        <td><%= item.subtotal %></td>
        <td><%= item.moneda %></td>
        <td><%= item.tc %></td>
          <% end %>
        <td><%= link_to 'Show', item %></td>
        <td><%= link_to 'Edit', edit_item_path(item) %></td>
        <td><%= link_to 'Destroy', item, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'New Item', new_item_path %>
