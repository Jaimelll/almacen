<p id="notice"><%= notice %></p>

<h1>Items</h1>
<th>Periodo= <%=   $vmes %></th>
<th>Origen= <%=   $vorigen %></th>
<th>Registros= <%=   @regis %></th>
<th>Subtotal= <%=   @acum %></th>

<table>
  <thead>
    <tr>
      <th>Pfecha</th>
      <th>Serie</th>
      <th>Factura</th>
      <th>Ruc</th>
      <th>Razon</th>
      <th>Subtotal</th>
      <th>Moneda</th>
      <th>Tc</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @items.each do |item| %>
      <tr>
        <td><%= item.pfecha %></td>
        <td><%= item.serie %></td>
        <td><%= item.nfactu %></td>
        <td><%= item.client.ruc if item.client %></td>
        <td><%= item.client.razon if item.client %></td>
        <td><%= item.subtotal %></td>
        <td><%= item.moneda %></td>
        <td><%= item.tc %></td>
        <td><%= link_to 'Show', item %></td>
        <td><%= link_to 'Edit', edit_item_path(item) %></td>
        <td><%= link_to 'Destroy', item, method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to 'New Item', new_item_path %>
