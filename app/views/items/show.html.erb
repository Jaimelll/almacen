<p id="notice"><%= notice %></p>
<h2>PARTE INGRESO DE DETALLES </h2>
<p>
  <strong>Periodo:</strong>
  <%= @item.mmes.strftime("%b-%Y") %>
  <strong>Empresa:</strong>
  <% if @item.empresa==1 %>
  Industrias
  <% end %>
  <% if @item.empresa==2 %>
  Confecciones
  <% end %>
  <strong>Origen:</strong>

  <% if @item.origen==1 %>
  Compras
  <% end %>
  <% if @item.origen==2 %>
  Ventas
  <% end %>
  <% if @item.origen==3 %>
  Pedido
  <% end %>
  <% if @item.origen==4 %>
   Orden de compra
  <% end %>
  <% if @item.origen==5 %>
  Produccion
  <% end %>
  <% if @item.origen==6 %>
  Inventario
  <% end %>






  </p>


<p>
  <strong>  Fecha: </strong>
  <%= @item.pfecha %>
<% if Parameter.find_by_id(1).origen<3 %>
  <strong>  Factura:</strong>
  <%= @item.serie %>-<%= @item.nfactu %>

  <strong>  Razon:</strong>
  <%= @item.client.razon %>

  <strong>Tc:</strong>
  <%= @item.tc %>

  <strong>Moneda:</strong>
  <% if @item.moneda==1 %>
  Soles
  <% end %>
  <% if @item.moneda==2 %>
  Dolares
  <% end %>


<% end %>
</p>


<br/>


<div class="field">
  <h3> DETALLES</h3>


<table>
  <thead>
    <tr>
      <th  style="width:150px;">Producto</th>
      <th  style="width:150px;">Descripcion</th>
      <th  style="width:50px;">Cantidad</th>
    <% if Parameter.find_by_id(1).origen<5 %>
      <th  style="width:50px;">Precio</th>
      <th  style="width:100px;">Monto</th>
     <% end %>

      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @item.details.each do |detail| %>
      <tr>
        <td><%= Product.find_by_id(detail.product_id).nombre if detail.product_id %></td>
        <td><%= detail.descripcion %></td>
        <td><%= detail.cantidad %></td>
      <% if Parameter.find_by_id(1).origen<5 %>
        <td><%= detail.precio %></td>
        <td><%= detail.monto %></td>
     <% end %>

        <td  style="width:50px;"><%= link_to 'Editar',edit_item_detail_path(@item,detail) %></td>
        <td  style="width:50px;"> <%= link_to 'Eliminar', item_detail_path(@item,detail), method: :delete, data: { confirm: 'Are you sure?' } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

  <br/>
  <br/>
  <h3><%= link_to '<Nuevo Detalle>', new_item_detail_path(@item) %> </h3>
</div>
<br/>
<p>
    <% if Parameter.find_by_id(1).origen<5 %>
      <strong  style="width:100px;">Subtotal</strong>
        <%= @item.subtotal %>
      <strong  style="width:100px;">Igv</strong>
       <%= @item.subtotal*0.18 %>
      <strong  style="width:100px;">Total</strong>
       <%= @item.subtotal*1.18 %>
    <% end %>

  </p>

<br/>

<%= link_to 'Editar', edit_item_path(@item) %> |
<%= link_to 'Retroceder', items_path %>
