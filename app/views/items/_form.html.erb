<%= form_for(item) do |f| %>
  <% if item.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(item.errors.count, "error") %> prohibited this item from being saved:</h2>

      <ul>
      <% item.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
      </ul>
    </div>
  <% end %>
  <div class="field">
    <%= f.label :Empresa %>
    <%= f.select :empresa, [['Industrias',1],['Confecciones',2]], selected: $vempresa %>
  </div>

  <div class="field">
    <%= f.label :Mes %>
    <%= f.date_select :mmes, discard_day:true, selected: $vmes %>
  </div>

  <div class="field">
    <%= f.label :Origen %>
    <%= f.select :origen, [['compras',1],['ventas',2]], selected: $vorigen %>
  </div>

  <div class="field">
    <%= f.label :Fecha %>

    <%= f.date_select :pfecha, selected: $vmes %>  
  </div>

  <div class="field">
    <%= f.label :factura %>
    <%= f.text_field :serie %>
    <%= f.text_field :nfactu %>
  </div>

  <div class="field">
    <%= f.label :Razon %>
    <%= f.collection_select :client_id, Client.all.order(:razon), :id, :razon %>
  </div>

    <div class="field">
    <%= f.label :moneda %>
    <%= f.select :moneda, [['Sol',1],['Dolar',2]] %>
  </div>

  <div class="field">
    <%= f.label :tc %>
    <%= f.text_field :tc %>
  </div>

  <div class="field">
    <%= f.label :Subtotal %>
    <%= f.text_field :subtotal, onchange: "{alert('IGV='+value*0.18+' TOTAL='+value*1.18);}" %>


  </div>

  <div class="actions">
    <%= f.submit %>
  </div>
<% end %>
