<%= form_for(item) do |f| %>
  <% if item.errors.any? %>
    <div id="error_explanation">
      <h2><%= pluralize(item.errors.count, "error") %> prohibited this item from being saved:</h2>

      <ul>
      <% item.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
      </ul>
    </div>
  <% end %>
  <div class="field">
    <%= f.label :Parametros %>
    <%= f.select :empresa, [['Industrias',1],['Confecciones',2]] %>

    <%= f.date_select :mmes, discard_day:true %>


    <%= f.select :origen, [['compras',1],['ventas',2],['pedido',3],['orden de compra',4],['produccion',5],['inventario',6]] %>


  </div>

  <div class="field">
    <%= f.label :Fecha %>

    <%= f.date_select :pfecha %>
  </div>
  <% if Parameter.find_by_id(1).origen<3 %>
    <div class="field">
       <%= f.label :factura %>
       <%= f.text_field :serie, :size => 4 %>
      <%= f.text_field :nfactu, :size => 10 %>

   </div>

   <div class="field">
    <%= f.label :Razon %>
    <%= f.collection_select :client_id, Client.all.order(:razon), :id, :razon, html_options = {:style => "width:600px"}  %>
   </div>


   <div class="field">
    <%= f.label :tc %>
    <%= f.text_field :tc %>
    <%= f.select :moneda, [['Sol',1],['Dolar',2]] %>
   </div>
  <% end %>
<br/>

  <div class="actions">
    <%= f.submit %>
  </div>
<% end %>
